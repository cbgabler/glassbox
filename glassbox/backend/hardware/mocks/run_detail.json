  "findings": [
    {
      "id": "f_001",
      "type": "tvla",
      "severity": "CRITICAL",
      "title": "Side-channel leak on cycles (order 1, |t|=312.4 > 4.5)",
      "detail": "Welch's t-test rejects H0 (input-independent execution) on the cycles channel with |t|=312.4. The function's mean cycles measurably depends on the secret input.",
      "remediation": "Stored credential checks should never short-circuit on the first wrong byte. Hash both sides (bcrypt/argon2) and compare with a constant-time equality.",
      "data": {
        "channel": "cycles",
        "order": 1,
        "t_abs": 312.4,
        "threshold": 4.5
      }
    },
    {
      "id": "f_002",
      "type": "tvla",
      "severity": "HIGH",
      "title": "Side-channel leak on power (order 1, |t|=27.8 > 4.5)",
      "detail": "Power-channel TVLA fires at sample 124, ~62% through the function -- consistent with the early-return branch.",
      "data": {
        "channel": "power",
        "order": 1,
        "t_abs": 27.8,
        "threshold": 4.5,
        "argmax_sample": 124,
        "fraction_through_function": 0.62
      }
    },
    {
      "id": "f_003",
      "type": "static",
      "severity": "HIGH",
      "title": "[CT001] `if` condition reads a secret-named value",
      "detail": "Static analysis on `gb_target.cpp:32` flagged a likely side-channel pattern before flashing. Rule CT001.\n\n```c\n        if (secret[i] != STORED_HASH[i]) {\n```",
      "remediation": "Replace the conditional with a constant-time mask: compute both branches and select with `(mask & a) | (~mask & b)`.",
